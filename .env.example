# NEXT_PUBLIC_SUPABASE_URL=your-project-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Daily.co API key for video rooms
# DAILY_API_KEY=your-daily-api-key
# NEXT_PUBLIC_DAILY_DOMAIN=your-domain.daily.co

# Optional: Resend API key if you implement email sending later
# RESEND_API_KEY=

# Set to true to disable actual API calls to external services during local dev
# NEXT_PUBLIC_MOCK_EXTERNAL_SERVICES=true
